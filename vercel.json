{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/css/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/chrome-browser-frame/",
      "dest": "/chrome-browser-frame/index.html"
    },
    {
      "src": "/safari-browser-frame/",
      "dest": "/safari-browser-frame/index.html"
    },
    {
      "src": "/firefox-browser-frame/",
      "dest": "/firefox-browser-frame/index.html"
    },
    {
      "src": "/edge-browser-frame/",
      "dest": "/edge-browser-frame/index.html"
    },
    {
      "src": "/macbook-screenshot-frame/",
      "dest": "/macbook-screenshot-frame/index.html"
    },
    {
      "src": "/imac-screenshot-frame/",
      "dest": "/imac-screenshot-frame/index.html"
    },
    {
      "src": "/ipad-screenshot-frame/",
      "dest": "/ipad-screenshot-frame/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": true
}